# Copiá este archivo a .env (gitignored) y completá los valores reales.

# Postgres (event store + read model)
POSTGRES_DB=gastnyahpdb
POSTGRES_USER=gastnyahp
POSTGRES_PASSWORD=elegí-una-contraseña-fuerte

# La API key del administrador de la app: habilita POST /api/admin/invites (emitir códigos de creación de
# familia). Sin ella, la puerta queda cerrada (503). Generá un valor largo y aleatorio.
GASTNYAHP_ADMIN_KEY=

# Development activa OpenAPI en /openapi
ASPNETCORE_ENVIRONMENT=Production
